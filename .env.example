# ===========================================
# Unitask Flutter - Required Setup Files
# ===========================================
# This project requires the following files that are NOT tracked by git.
# You must create/obtain them before building the project.
#
# 1. android/app/google-services.json
#    - Download from Firebase Console > Project Settings > Android app
#    - https://console.firebase.google.com
#
# 2. lib/firebase_options.dart
#    - Auto-generated by running:
#      $ flutterfire configure
#    - Requires FlutterFire CLI: dart pub global activate flutterfire_cli
#
# 3. assets/service_account.json
#    - GCP service account key for backend services
#    - Obtain from project admin or GCP Console > IAM > Service Accounts
#
# ===========================================
# Steps to get started:
# ===========================================
# 1. Clone the repo
# 2. Get google-services.json from Firebase Console
# 3. Run: flutterfire configure
# 4. Get service_account.json from project admin
# 5. Run: flutter pub get
# 6. Run: flutter run
